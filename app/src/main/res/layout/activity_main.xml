<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SARA Developer Dashboard"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Telegram Bot Token"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/tokenInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter bot token"
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/saveTokenBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save Token"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#1976D2" />

            <Button
                android:id="@+id/testTokenBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Test Token"
                android:layout_marginStart="4dp"
                android:backgroundTint="#7B1FA2" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Service Controls"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/startBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#388E3C" />

            <Button
                android:id="@+id/stopBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#D32F2F" />

            <Button
                android:id="@+id/restartBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Restart"
                android:layout_marginStart="4dp"
                android:backgroundTint="#F57C00" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permissions"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <!-- Permissions Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <!-- Notifications -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1E1E1E" android:padding="12dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notification Access" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Required to read and reply to messages from other apps." android:textColor="#999999" android:textSize="12sp" android:layout_marginTop="4dp" />
                <Button android:id="@+id/grantNotificationBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Status: Checking..." android:layout_marginTop="8dp" android:backgroundTint="#1976D2" />
            </LinearLayout>

            <!-- Screen Capture -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1E1E1E" android:padding="12dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Screen Capture" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Allows SARA to take screenshots via the /screenshot command." android:textColor="#999999" android:textSize="12sp" android:layout_marginTop="4dp" />
                <Button android:id="@+id/grantScreenCaptureBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Status: Checking..." android:layout_marginTop="8dp" android:backgroundTint="#1976D2" />
            </LinearLayout>

            <!-- Camera -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1E1E1E" android:padding="12dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Camera" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Allows SARA to take photos using the /camera command." android:textColor="#999999" android:textSize="12sp" android:layout_marginTop="4dp" />
                <Button android:id="@+id/grantCameraBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Status: Checking..." android:layout_marginTop="8dp" android:backgroundTint="#1976D2" />
            </LinearLayout>

            <!-- Location -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1E1E1E" android:padding="12dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Location" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Enables tracking and GPS commands (/location, /track)." android:textColor="#999999" android:textSize="12sp" android:layout_marginTop="4dp" />
                <Button android:id="@+id/grantLocationBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Status: Checking..." android:layout_marginTop="8dp" android:backgroundTint="#1976D2" />
            </LinearLayout>

            <!-- Usage Stats -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1E1E1E" android:padding="12dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Usage Stats" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Used for automation rules that trigger when specific apps are opened or closed." android:textColor="#999999" android:textSize="12sp" android:layout_marginTop="4dp" />
                <Button android:id="@+id/grantUsageStatsBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Status: Checking..." android:layout_marginTop="8dp" android:backgroundTint="#1976D2" />
            </LinearLayout>

            <!-- Device Admin -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1E1E1E" android:padding="12dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Device Admin" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Allows SARA to instantly lock your device via the /lock command." android:textColor="#999999" android:textSize="12sp" android:layout_marginTop="4dp" />
                <Button android:id="@+id/grantDeviceAdminBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Status: Checking..." android:layout_marginTop="8dp" android:backgroundTint="#1976D2" />
            </LinearLayout>

            <!-- Battery Optimization -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1E1E1E" android:padding="12dp" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Battery Exemption" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Prevents Android from killing SARA in the background, ensuring 24/7 reliability." android:textColor="#999999" android:textSize="12sp" android:layout_marginTop="4dp" />
                <Button android:id="@+id/grantBatteryBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Status: Checking..." android:layout_marginTop="8dp" android:backgroundTint="#1976D2" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/serviceStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Stopped"
            android:textColor="#FF5252"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="#1E1E1E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Health"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="8dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/uptimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Uptime: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/memoryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memory: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/modulesText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modules: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/eventCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Events: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/telegramStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Telegram: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/lastErrorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Error: --"
                android:textColor="#FF5252"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Logs"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/clearLogsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ Clear ]"
            android:textColor="#1976D2"
            android:textSize="12sp"
            android:padding="4dp" />

        <ScrollView
            android:id="@+id/logScroll"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="4dp"
            android:background="#0D0D0D"
            android:padding="6dp">

            <TextView
                android:id="@+id/logConsole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00E676"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp" />
        </ScrollView>

    </LinearLayout>
</ScrollView>
